<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="23727" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" colorMatched="YES">
    <dependencies>
        <deployment identifier="iOS"/>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="23721"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <collectionViewCell opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" id="cell" customClass="TrackCollectionViewCell" customModuleProvider="target" reuseIdentifier="TrackCollectionViewCell">
            <rect key="frame" x="0.0" y="0.0" width="340" height="100"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <view key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center">
                <rect key="frame" x="0.0" y="0.0" width="340" height="100"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <imageView id="cover" contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO"/>
                    <label id="name" numberOfLines="1" translatesAutoresizingMaskIntoConstraints="NO">
                        <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="18"/>
                    </label>
                    <label id="artist" numberOfLines="1" translatesAutoresizingMaskIntoConstraints="NO">
                        <fontDescription key="fontDescription" type="system" weight="thin" pointSize="18"/>
                    </label>
                </subviews>
            </view>
            <constraints>
                <constraint firstItem="cover" firstAttribute="top" secondItem="cell" secondAttribute="top" id="c1"/>
                <constraint firstItem="cover" firstAttribute="leading" secondItem="cell" secondAttribute="leading" id="c2"/>
                <constraint firstItem="cover" firstAttribute="width" secondItem="cell" secondAttribute="width" multiplier="0.25" id="c3"/>
                <constraint firstAttribute="bottom" secondItem="cover" secondAttribute="bottom" id="c4"/>
                <constraint firstItem="name" firstAttribute="top" secondItem="cell" secondAttribute="top" id="c5"/>
                <constraint firstItem="name" firstAttribute="leading" secondItem="cover" secondAttribute="trailing" constant="5" id="c6"/>
                <constraint firstAttribute="trailing" secondItem="name" secondAttribute="trailing" constant="10" id="c7"/>
                <constraint firstItem="artist" firstAttribute="top" secondItem="name" secondAttribute="bottom" id="c8"/>
                <constraint firstItem="artist" firstAttribute="leading" secondItem="cover" secondAttribute="trailing" constant="5" id="c9"/>
                <constraint firstAttribute="trailing" secondItem="artist" secondAttribute="trailing" constant="10" id="c10"/>
                <constraint firstAttribute="bottom" secondItem="artist" secondAttribute="bottom" id="c11"/>
            </constraints>
            <connections>
                <outlet property="trackCoverView" destination="cover" id="outlet-cover"/>
                <outlet property="trackNameLabel" destination="name" id="outlet-name"/>
                <outlet property="artistNameLabel" destination="artist" id="outlet-artist"/>
            </connections>
        </collectionViewCell>
    </objects>
</document>


